{
  "$schema": "../rpc-schema-draft.json",
  "type": "object",
  "added": "v22.11",
  "rpc": "reckless",
  "title": "Reckless, a plugin manager",
  "description": [
    "The **reckless** RPC lets you manage plugins. It has multiple commands available, best described in the **help** command."
  ],
  "request": {
    "required": [
      "command"
    ],
    "additionalProperties": false,
    "properties": {
      "command": {
        "type": "string",
        "enum": [
          "install",
          "update",
          "uninstall",
          "listavailable",
          "listinstalled",
          "enable",
          "disable",
          "source",
          "tip",
          "help"
        ],
        "description": [
          "Determines which command to pass to reckless",
          "  - *command* **install** takes a *plugin_name* to search for and install a named plugin.",
          "  - *command* **uninstall** takes a *plugin_name* and attempts to uninstall a plugin of the same name.",
          "  - *command* **help** takes a *command* to display help for (plain text).",
          "..."
        ]
      },
      "subcommand": {
        "type": "string",
        "enum": [
          "add",
          "list",
          "remove"
        ],
        "description": [
          "A subcommand. Only in combination with *command* **source**."
        ]
      },
      "target": {
        "type": "string",
        "description": [
          "*name* of a plugin to install/update/uninstall/listavailable/enable/disable or source to add/remove. Can also have a git ref added with `<name>@<ref>` to install a specific version."
        ]
      },
      "options": {
        "type": "array",
        "added": "v26.09",
        "items": {
          "type": "string"
        },
        "description": [
          "Plugin options to be used with the commands **install**/**update**/**enable** in the form of `key=value`."
        ]
      },
      "amount_msat": {
        "type": "msat",
        "added": "v26.09",
        "description": [
          "The amount of msat to send when using the *command* **tip**."
        ]
      },
      "payer_note": {
        "type": "string",
        "added": "v26.09",
        "description": [
          "A message that a payer is willing to send to a payee when using the *command* **tip**."
        ]
      },
      "verbose": {
        "type": "boolean",
        "added": "v26.09",
        "description": [
          "Verbose output for all logging outputs for this command."
        ]
      },
      "developer": {
        "type": "boolean",
        "added": "v26.09",
        "description": [
          "Build plugins in debug mode and do not clean up build files where applicable."
        ]
      }
    }
  },
  "response": {
    "required": [
      "log"
    ],
    "additionalProperties": false,
    "properties": {
      "install": {
        "type": "object",
        "added": "v26.09",
        "properties": {
          "plugin_name": {
            "type": "string",
            "description": [
              "The name of the plugin that was installed."
            ]
          },
          "enabled": {
            "type": "boolean",
            "description": [
              "Whether the plugin was enabled or not."
            ]
          },
          "installed_commit": {
            "type": "string",
            "description": [
              "The git ref that was installed. Only present if source is a remote git repository."
            ]
          }
        },
        "required": [
          "plugin_name",
          "enabled"
        ],
        "additionalProperties": false
      },
      "update": {
        "type": "array",
        "added": "v26.09",
        "items": {
          "type": "object",
          "properties": {
            "plugin_name": {
              "type": "string",
              "description": [
                "The name of the plugin that was updated."
              ]
            },
            "enabled": {
              "type": "boolean",
              "description": [
                "Whether the plugin was enabled or not."
              ]
            },
            "installed_commit": {
              "type": "string",
              "description": [
                "The git ref that the plugin was updated to. Only present if source is a remote git repository."
              ]
            }
          },
          "required": [
            "plugin_name",
            "enabled"
          ],
          "additionalProperties": false
        }
      },
      "uninstall": {
        "type": "object",
        "added": "v26.09",
        "properties": {
          "plugin_name": {
            "type": "string",
            "description": [
              "The name of the plugin that was uninstalled."
            ]
          }
        },
        "required": [
          "plugin_name"
        ],
        "additionalProperties": false
      },
      "enable": {
        "type": "object",
        "added": "v26.09",
        "properties": {
          "plugin_name": {
            "type": "string",
            "description": [
              "The name of the plugin that was enabled."
            ]
          }
        },
        "required": [
          "plugin_name"
        ],
        "additionalProperties": false
      },
      "disable": {
        "type": "object",
        "added": "v26.09",
        "properties": {
          "plugin_name": {
            "type": "string",
            "description": [
              "The name of the plugin that was disabled."
            ]
          }
        },
        "required": [
          "plugin_name"
        ],
        "additionalProperties": false
      },
      "listavailable": {
        "type": "array",
        "added": "v26.09",
        "items": {
          "type": "object",
          "properties": {
            "plugin_name": {
              "type": "string",
              "description": [
                "The name of the plugin that was listed."
              ]
            },
            "installer": {
              "type": "string",
              "enum": [
                "PythonUv",
                "PythonUvShebang",
                "PythonUvLegacy",
                "PoetryVenv",
                "PyprojectViaPip",
                "Python",
                "Nodejs",
                "Rust",
                "Go",
                "Custom"
              ],
              "description": [
                "The name of the plugin installer that will be used."
              ]
            },
            "manifest": {
              "type": "object",
              "properties": {
                "short_description": {
                  "type": "string",
                  "description": [
                    "A short description of the plugin."
                  ]
                },
                "long_description": {
                  "type": "string",
                  "description": [
                    "A long description of the plugin."
                  ]
                },
                "entrypoint": {
                  "type": "string",
                  "description": [
                    "The entrypoint for the plugin."
                  ]
                },
                "dependencies": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "description": [
                    "Programs needed to install this plugin."
                  ]
                },
                "install_cmd": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "description": [
                    "Custom commands needed to install this plugin, if the default installers do not work."
                  ]
                },
                "required_options": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "description": [
                    "Options needed to install this plugin."
                  ]
                },
                "offer": {
                  "type": "string",
                  "description": [
                    "An offer for users to tip for this plugin."
                  ]
                },
                "installable": {
                  "type": "boolean",
                  "description": [
                    "Whether this plugin is reckless-installable."
                  ]
                }
              },
              "required": [
                "entrypoint"
              ],
              "additionalProperties": false
            },
            "origin": {
              "type": "string",
              "description": [
                "The origin of the plugin."
              ]
            }
          },
          "required": [
            "plugin_name",
            "installer",
            "manifest",
            "origin"
          ],
          "additionalProperties": false
        }
      },
      "listinstalled": {
        "type": "array",
        "added": "v26.09",
        "items": {
          "type": "object",
          "properties": {
            "plugin_name": {
              "type": "string",
              "description": [
                "The name of the plugin that was listed."
              ]
            },
            "installation_date": {
              "type": "string",
              "description": [
                "The date the plugin was installed."
              ]
            },
            "installation_time": {
              "type": "number",
              "description": [
                "The timestamp the plugin was installed."
              ]
            },
            "original_source": {
              "type": "string",
              "description": [
                "The original source of the plugin."
              ]
            },
            "requested_commit": {
              "type": "string",
              "description": [
                "The git ref that was requested to be installed."
              ]
            },
            "installed_commit": {
              "type": "string",
              "description": [
                "The git ref that was installed."
              ]
            }
          },
          "required": [
            "plugin_name",
            "installation_date",
            "installation_time",
            "original_source"
          ],
          "additionalProperties": false
        }
      },
      "sources": {
        "type": "array",
        "added": "v26.09",
        "items": {
          "type": "string"
        },
        "description": [
          "The list of current sources."
        ]
      },
      "tip": {
        "type": "object",
        "added": "v26.09",
        "properties": {
          "payment_preimage": {
            "type": "secret",
            "description": [
              "The proof of payment: SHA256 of this **payment_hash**."
            ]
          },
          "failed_parts": {
            "type": "u64",
            "description": [
              "How many separate payment parts failed."
            ]
          },
          "successful_parts": {
            "type": "u64",
            "description": [
              "How many separate payment parts succeeded (or are anticipated to succeed).  This will be at least one."
            ]
          },
          "amount_msat": {
            "type": "msat",
            "description": [
              "Amount the recipient received."
            ]
          },
          "amount_sent_msat": {
            "type": "msat",
            "description": [
              "Total amount we sent (including fees)."
            ]
          }
        },
        "required": [
          "payment_preimage",
          "failed_parts",
          "successful_parts",
          "amount_msat",
          "amount_sent_msat"
        ]
      },
      "log": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "description": [
          "Log entries of the requested reckless command."
        ]
      }
    }
  },
  "author": [
    "Alex Myers [alex@endothermic.dev](mailto:alex@endothermic.dev) is mainly responsible for the original python reckless.",
    "daywalker90 [daywalker990@gmx.de](mailto:daywalker990@gmx.de) is mainly responsible for the current rust reckless."
  ],
  "see_also": [
    "reckless(1)"
  ],
  "resources": [
    "Main web site: [https://github.com/ElementsProject/lightning](https://github.com/ElementsProject/lightning)"
  ],
  "examples": [
    {
      "request": {
        "id": "example:reckless#1",
        "method": "reckless",
        "params": {
          "command": "install",
          "target": "summary"
        }
      },
      "response": {
        "install": {
          "enabled": false,
          "installed_commit": "002761088174c151237e8a847c50603db20d5abf",
          "plugin_name": "summary"
        },
        "log": [
          "INFO: running command: `git clone --recursive https://github.com/lightningd/plugins /tmp/ltests-88arihe3/test_generate_examples_1/lightning-1/reckless/lightningd/plugins`",
          "<snip>",
          "INFO: running command: `git submodule sync --recursive` (cwd: /tmp/ltests-88arihe3/test_generate_examples_1/lightning-1/reckless/lightningd/plugins)",
          "<snip>",
          "INFO: running command: `git submodule update --init --recursive` (cwd: /tmp/ltests-88arihe3/test_generate_examples_1/lightning-1/reckless/lightningd/plugins)",
          "WARNING: could not detect installer for /tmp/ltests-88arihe3/test_generate_examples_1/lightning-1/reckless/lightningd/plugins: entryfile not found",
          "INFO: Plugins matching 'summary':",
          "INFO:   summary (https://github.com/lightningd/plugins)",
          "INFO: found summary in source: https://github.com/lightningd/plugins",
          "INFO: running command: `git pull --ff-only` (cwd: /tmp/ltests-88arihe3/test_generate_examples_1/lightning-1/reckless/lightningd/plugins)",
          "INFO: Already up to date.",
