{
  "$schema": "../rpc-schema-draft.json",
  "type": "object",
  "rpc": "reckless",
  "title": "Reckless, a plugin manager",
  "description": [
    "The **reckless** RPC lets you manage plugins. It has multiple commands available, best described in the **help** command."
  ],
  "request": {
    "required": [
      "command"
    ],
    "additionalProperties": false,
    "properties": {
      "command": {
        "type": "string",
        "enum": [
          "install",
          "update",
          "uninstall",
          "listavailable",
          "listinstalled",
          "enable",
          "disable",
          "source",
          "tip",
          "help"
        ],
        "description": [
          "Determines which command to pass to reckless",
          "  - *command* **install** takes a *plugin_name* to search for and install a named plugin.",
          "  - *command* **uninstall** takes a *plugin_name* and attempts to uninstall a plugin of the same name.",
          "  - *command* **help** takes a *command* to display help for (plain text).",
          "..."
        ]
      },
      "subcommand": {
        "type": "string",
        "enum": [
          "add",
          "list",
          "remove"
        ],
        "description": [
          "A subcommand. Only in combination with *command* **source**."
        ]
      },
      "target": {
        "type": "string",
        "description": [
          "*name* of a plugin to install/update/uninstall/listavailable/enable/disable or source to add/remove. Can also have a git ref added with `<name>@<ref>` to install a specific version."
        ]
      },
      "options": {
        "type": "array",
        "added": "v26.09",
        "items": {
          "type": "string"
        },
        "description": [
          "Plugin options to be used with the commands **install**/**update**/**enable** in the form of `key=value`."
        ]
      },
      "amount_msat": {
        "type": "msat",
        "added": "v26.09",
        "description": [
          "The amount of msat to send when using the *command* **tip**."
        ]
      },
      "payer_note": {
        "type": "string",
        "added": "v26.09",
        "description": [
          "A message that a payer is willing to send to a payee when using the *command* **tip**."
        ]
      },
      "verbose": {
        "type": "boolean",
        "added": "v26.09",
        "description": [
          "Verbose output for all logging outputs for this command."
        ]
      },
      "developer": {
        "type": "boolean",
        "added": "v26.09",
        "description": [
          "Build plugins in debug mode and do not clean up build files where applicable."
        ]
      }
    }
  },
  "response": {
    "required": [
      "log",
      "result"
    ],
    "additionalProperties": false,
    "properties": {
      "result": {
        "type": "array",
        "items": {
          "oneOf": [
            {
              "type": "object",
              "properties": {
                "plugin_name": {
                  "type": "string",
                  "description": [
                    "The name of the plugin that was installed or updated."
                  ]
                },
                "enabled": {
                  "type": "boolean",
                  "description": [
                    "Whether the plugin was enabled or not."
                  ]
                },
                "installed_commit": {
                  "type": "string",
                  "description": [
                    "The git ref that was installed or updated to. Only present if source is a remote git repository."
                  ]
                }
              },
              "required": [
                "plugin_name",
                "enabled"
              ],
              "additionalProperties": false
            },
            {
              "type": "object",
              "properties": {
                "plugin_name": {
                  "type": "string",
                  "description": [
                    "The name of the plugin that was uninstalled/enabled/disabled."
                  ]
                }
              },
              "required": [
                "plugin_name"
              ],
              "additionalProperties": false
            },
            {
              "type": "object",
              "properties": {
                "plugin_name": {
                  "type": "string",
                  "description": [
                    "The name of the plugin that was listed."
                  ]
                },
                "installer": {
                  "type": "string",
                  "enum": [
                    "PythonUv",
                    "PythonUvShebang",
                    "PythonUvLegacy",
                    "PoetryVenv",
                    "PyprojectViaPip",
                    "Python",
                    "Nodejs",
                    "Rust",
                    "Go",
                    "Custom"
                  ],
                  "description": [
                    "The name of the plugin installer that is used."
                  ]
                },
                "manifest": {
                  "type": "object",
                  "properties": {
                    "short_description": {
                      "type": "string",
                      "description": [
                        "A short description of the plugin."
                      ]
                    },
                    "long_description": {
                      "type": "string",
                      "description": [
                        "A long description of the plugin."
                      ]
                    },
                    "entrypoint": {
                      "type": "string",
                      "description": [
                        "The entrypoint for the plugin."
                      ]
                    },
                    "dependencies": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      },
                      "description": [
                        "Programs needed to install this plugin."
                      ]
                    },
                    "install_cmd": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      },
                      "description": [
                        "Custom commands needed to install this plugin, if the default installers do not work."
                      ]
                    },
                    "required_options": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      },
                      "description": [
                        "Options needed to install this plugin."
                      ]
                    },
                    "offer": {
                      "type": "string",
                      "description": [
                        "An offer for users to tip for this plugin."
                      ]
                    },
                    "installable": {
                      "type": "boolean",
                      "description": [
                        "Whether this plugin is reckless-installable."
                      ]
                    }
                  },
                  "required": [
                    "entrypoint"
                  ],
                  "additionalProperties": false
                },
                "origin": {
                  "type": "string",
                  "description": [
                    "The origin of the plugin."
                  ]
                }
              },
              "required": [
                "plugin_name",
                "installer",
                "manifest",
                "origin"
              ],
              "additionalProperties": false
            },
            {
              "type": "object",
              "properties": {
                "plugin_name": {
                  "type": "string",
                  "description": [
                    "The name of the plugin that was listed."
                  ]
                },
                "installation_date": {
                  "type": "string",
                  "description": [
                    "The date the plugin was installed."
                  ]
                },
                "installation_time": {
                  "type": "number",
                  "description": [
                    "The timestamp the plugin was installed."
                  ]
                },
                "original_source": {
                  "type": "string",
                  "description": [
                    "The original source of the plugin."
                  ]
                },
                "requested_commit": {
                  "type": "string",
                  "description": [
                    "The git ref that was requested to be installed."
                  ]
                },
                "installed_commit": {
                  "type": "string",
                  "description": [
                    "The git ref that was installed."
                  ]
                }
              },
              "required": [
                "plugin_name",
                "installation_date",
                "installation_time",
                "original_source"
              ],
              "additionalProperties": false
            },
            {
              "type": "object",
              "properties": {
                "sources": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "description": [
                    "The list of current sources."
                  ]
                }
              },
              "required": [
                "sources"
              ],
              "additionalProperties": false
            },
            {
              "type": "object",
              "properties": {
                "payment_preimage": {
                  "type": "secret",
                  "description": [
                    "The proof of payment: SHA256 of this **payment_hash**."
                  ]
                },
                "failed_parts": {
                  "type": "u64",
                  "description": [
                    "How many separate payment parts failed."
                  ]
                },
                "successful_parts": {
                  "type": "u64",
                  "description": [
                    "How many separate payment parts succeeded (or are anticipated to succeed).  This will be at least one."
                  ]
                },
                "amount_msat": {
                  "type": "msat",
                  "description": [
                    "Amount the recipient received."
                  ]
                },
                "amount_sent_msat": {
                  "type": "msat",
                  "description": [
                    "Total amount we sent (including fees)."
                  ]
                }
              },
              "required": [
                "payment_preimage",
                "failed_parts",
                "successful_parts",
                "amount_msat",
                "amount_sent_msat"
              ]
            }
          ]
        },
        "description": [
          "Output of the requested reckless command."
        ]
      },
      "log": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "description": [
          "Log entries of the requested reckless command."
        ]
      }
    }
  },
  "author": [
    "Alex Myers [alex@endothermic.dev](mailto:alex@endothermic.dev) is mainly responsible."
  ],
  "see_also": [
    "reckless(1)"
  ],
  "resources": [
    "Main web site: [https://github.com/ElementsProject/lightning](https://github.com/ElementsProject/lightning)"
  ],
  "examples": [
    {
      "request": {
        "id": "example:reckless#1",
        "method": "reckless",
        "params": {
          "command": "search",
          "target/subcommand": "backup"
        }
      },
      "response": {
        "result": [
          "https://github.com/lightningd/plugins"
        ],
        "log": [
          "DEBUG: Warning: Reckless requires write access",
          "DEBUG: fetching from gh API: https://api.github.com/repos/lightningd/plugins/contents/",
          "DEBUG: fetching from gh API: https://api.github.com/repos/lightningd/plugins/git/trees/294f93d7060799439c994daa84f534c4d1458325",
          "INFO: found backup in source: https://github.com/lightningd/plugins",
          "DEBUG: entry: None",
          "DEBUG: sub-directory: backup"
        ]
      }
    },
    {
      "request": {
        "id": "example:reckless#2",
        "method": "reckless",
        "params": {
          "command": "install",
          "target/subcommand": [
