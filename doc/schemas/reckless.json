    },
    {
      "request": {
        "id": "example:reckless#1",
        "method": "reckless",
        "params": {
          "command": "tip",
          "target": "summary",
          "amount_msat": 1000,
          "payer_note": "thanks!"
        }
      },
      "response": {
        "tip": {
          "amount_msat": 1000,
          "amount_sent_msat": 1000,
          "failed_parts": 0,
          "payment_preimage": "940148d45ce964205c289a215d2b45e7bad32caa4318eb1977184fe424d04a00",
