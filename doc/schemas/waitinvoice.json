        "bolt11": "lnbcrt20n1pne035qsp59v3v5ksna0cgcgwupg6h4xsg3dvwk06ly4jh0ghytrcghrnypqnspp50te9vj4kzy733vkc29uv5elz30v9rzpyzq0kcsnyj0dq2h9mt4hsdq8d9h8vvsxqyjw5qcqp99qxpqysgqk8lwpzs9pmkm9a0mda42xcj3m7q29np2erxqp93dce9sreczgprqndyktadx78yljnsaw0zrkjw6hhkkzgthph94hcat9ej64p2jwdqqyysl70",
        "payment_hash": "7af2564ab6113d18b2d85178ca67e28bd8518824101f6c426493da055cbb5d6f",
        "amount_msat": 2000,
        "status": "paid",
        "pay_index": 5,
        "amount_received_msat": 2000,
        "paid_at": 1738000000,
        "payment_preimage": "09e7f193a0100ea809e7f193a0100ea809e7f193a0100ea809e7f193a0100ea8",
