            "groupid": 8789338917165744446,
            "updated_index": 22,
            "partid": 1,
            "destination": "03cecbfdc68544cc596223b68ce0710c9e5d2c9cb317ee07822d95079acc703d31",
            "amount_msat": 50000000,
            "amount_sent_msat": 50000501,
            "created_at": 1738000000,
