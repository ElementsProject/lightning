            "payment_hash": "19472d43110fb74d7c29468b1aec09ad2f00a91faf7b1b3974d07630defe76a1",
            "groupid": 7924647788710609214,
            "updated_index": 1,
            "partid": 1,
            "destination": "033845802d25b4e074ccfd7cd8b339a41dc75bf9978a034800444b51d42b07799a",
            "amount_msat": 500000000,
            "amount_sent_msat": 500000000,
            "created_at": 1738000000,
            "completed_at": 1738000000,
            "status": "complete",
            "payment_preimage": "09e7f193a0100e9f09e7f193a0100e9f09e7f193a0100e9f09e7f193a0100e9f",
