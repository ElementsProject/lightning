        "id": "example:commando#1",
        "method": "commando",
        "params": {
          "peer_id": "033845802d25b4e074ccfd7cd8b339a41dc75bf9978a034800444b51d42b07799a",
          "rune": "7cKJyALVY0_LLVV-AB9oetXjipOdyt0EhOuYrSS42fM9MA==",
          "method": "newaddr",
          "params": {
            "addresstype": "p2tr"
          }
        }
      },
