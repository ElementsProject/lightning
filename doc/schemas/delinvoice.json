        "id": "example:delinvoice#1",
        "method": "delinvoice",
        "params": {
          "label": "lbl_l36",
          "status": "unpaid"
        }
      },
      "response": {
        "label": "lbl_l36",
        "bolt11": "lnbcrt500u1pne035qsp5zkz2glrfqgvw7dar86umteldh7rrspqg6qt0s7t5qrs2zwr7urkspp5msm0sn03dnp47a5vtfx9qvzdscqluuwnzupy5hx0ulqswwa4j7wqdqcdsenvgryv4ekxunfwp6xjmmwxqyjw5qcqp99qxpqysgqajsulk3lmdklgd8y6vf942m874kpgew4xnk3qp8dxz0jz4nscn6r6wxmuu8fw76nhcpcpqyzgrwgk0eqjv5hzja6cqdp22wv8de3mygp7kgefl",
        "payment_hash": "dc36f84df16cc35f768c5a4c50304d8601fe71d317024a5ccfe7c1073bb5979c",
        "amount_msat": 50000000,
        "status": "unpaid",
        "description": "l36 description",
        "expires_at": 1738604800,
