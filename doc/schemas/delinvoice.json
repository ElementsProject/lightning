        "method": "delinvoice",
        "params": {
          "label": "lbl_l37",
          "status": "paid",
          "desconly": true
        }
      },
      "response": {
        "label": "lbl_l37",
        "bolt11": "lnbcrt500u1pne035qsp5h4ctf82jng2sd6uqzsmzn32r7w2mjhdgsa2tlayr7c2e2s2727jqpp5xq8txm0yn56cf3k7jg46dnqrdhukl87g605vrjyx6p2vk3tpay2sdqcdsenwgryv4ekxunfwp6xjmmwxqyjw5qcqp99qxpqysgqeypx4zjc3tupr0wzlryztjgsme4zgfh6vk9fw504fx7ctrpg6nvsnse9kmwzy3h8km53rfa9cfvrufp7ycfhpndfqkzk6p6khws2c7spyevnqf",
        "payment_hash": "300eb36de49d3584c6de922ba6cc036df96f9fc8d3e8c1c886d054cb4561e915",
        "amount_msat": 50000000,
        "status": "paid",
        "pay_index": 9,
        "amount_received_msat": 50000000,
        "paid_at": 1738000000,
        "payment_preimage": "3e3b17b070d9dc503e3b17b070d9dc503e3b17b070d9dc503e3b17b070d9dc50",
