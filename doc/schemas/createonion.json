        "params": {
          "hops": [
            {
              "pubkey": "033845802d25b4e074ccfd7cd8b339a41dc75bf9978a034800444b51d42b07799a",
              "payload": "11020203e804019706080000760000010000"
            },
            {
              "pubkey": "03cecbfdc68544cc596223b68ce0710c9e5d2c9cb317ee07822d95079acc703d31",
              "payload": "11020203e804019706080000780000010000"
            },
            {
              "pubkey": "02287bfac8b99b35477ebe9334eede1e32b189e24644eb701c079614712331cec0",
              "payload": "2b020203e80401910822d7768066e4322f8e4603fac079d72d39757655eae27e46057913bd038bd670cd03e8"
            }
          ],
          "assocdata": "c604fdfab4dc32f8efe4d02afb2a8e1284df9bb3853ad9a91324c1c40dfc94da"
        }
      },
      "response": {
        "onion": "",
        "shared_secrets": [
          "70b1d48484a1640b979bbf3f5b29792dcda347cfa994b9efa1a6d6ca20945fec",
          "587326519609b5997d238ccdfe9cc359d3439e991738a66eea4d178ec1fe9e9c",
          "4ee7c3dfe58f7c3e316b433ab20394ab4330a6dcb3dda76d1d184335afc6c4ad"
        ]
